# =============================================================================
# .gitignore — Infra Entreprise 3
# =============================================================================

# Credentials Vault (JAMAIS dans git)
# vault-credentials/

# Clés WireGuard générées
# wg0.conf générés par vault-init.sh (contiennent les clés privées)
# config/wireguard/3a/wg0.conf
# config/wireguard/3b/wg0.conf

# config/wireguard/3a/privatekey
# config/wireguard/3a/publickey
# config/wireguard/3b/privatekey
# config/wireguard/3b/publickey

# Fichiers secrets injectés par Vault Agent au runtime
# **/*.env
# **/sip-secrets.conf

# Certificats OpenVPN générés
# *.ovpn
# config/openvpn/pki/

# Données persistantes Docker (si montées en local)
data/

# Logs
*.log
*.DS_Store
install-deps-macos.sh