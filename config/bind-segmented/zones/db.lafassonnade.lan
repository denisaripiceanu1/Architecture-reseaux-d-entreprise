$TTL 86400
@   IN  SOA dns.lafassonnade.lan. admin.lafassonnade.lan. (
        2026052701 ; serial
        3600       ; refresh
        1800       ; retry
        604800     ; expire
        86400 )    ; minimum

@           IN  NS  dns.lafassonnade.lan.

; Réseau services — 192.168.3.0/24
dns         IN  A   192.168.3.1
dhcp        IN  A   192.168.3.2
ldap        IN  A   192.168.3.5
ldapadmin   IN  A   192.168.3.6
vpn         IN  A   192.168.3.10
vault       IN  A   192.168.3.15
vault-agent-ldap IN A 192.168.3.16
vault-init  IN  A   192.168.3.17
portainer   IN  A   192.168.3.20
pfsense-services IN A 192.168.3.254

; Réseau voix — 192.168.30.0/24
voip        IN  A   192.168.30.3
asterisk    IN  CNAME voip.lafassonnade.lan.
pfsense-voice IN A 192.168.30.254

; DMZ — 192.168.40.0/24
web         IN  A   192.168.40.4
pfsense-dmz IN  A   192.168.40.254
